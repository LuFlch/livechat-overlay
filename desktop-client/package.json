{
  "name": "livechat-ccb-desktop",
  "version": "1.2.2",
  "private": true,
  "description": "Desktop overlay client for LiveChat CCB",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jeremie-pires/livechat-overlay.git"
  },
  "author": "jere",
  "main": "dist/main.js",
  "scripts": {
    "dev": "npm run build && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "node scripts/copy-renderer.mjs",
    "dist": "npm run build && electron-builder --win nsis",
    "pack": "npm run build && electron-builder --dir",
    "release": "npm run build && electron-builder --win nsis --publish always"
  },
  "build": {
    "appId": "fr.livechat.ccb.desktop",
    "productName": "LiveChatCCB Desktop",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "LiveChatCCB-Desktop-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LiveChatCCB Desktop"
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "20.11.17",
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "5.3.3"
  }
}
