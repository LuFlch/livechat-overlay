generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Queue {
  id String @id @default(uuid())

  type    String
  content String

  author      String?
  authorImage String?

  submissionDate    DateTime  @default(now())
  executionDate     DateTime  @default(now())
  duration          Int
  discordGuildId    String
  discordReceivedAt DateTime?
  processingMs      Int?
  busyRequeueMs     Int       @default(0)

  @@index([type])
}

model Guild {
  id               String    @id
  busyUntil        DateTime?
  defaultMediaTime Int?
  maxMediaTime     Int?
  displayMediaFull Boolean   @default(false)
  channelId        String?
}

model Stats {
  id                   String  @id @default("singleton")
  silentMode           Boolean @default(false)
  totalSent            Int     @default(0)
  imageCount           Int     @default(0)
  videoCount           Int     @default(0)
  audioCount           Int     @default(0)
  linkCount            Int     @default(0)
  textCount            Int     @default(0)
  totalLatencyMs       Int     @default(0)
  latencyCount         Int     @default(0)
  totalPayloadBytes    Int     @default(0)
  totalIngestionMs     Int     @default(0)
  ingestionCount       Int     @default(0)
  totalQueueWaitMs     Int     @default(0)
  queueWaitCount       Int     @default(0)
  totalProcessingMs    Int     @default(0)
  processingCount      Int     @default(0)
  totalEmitMs          Int     @default(0)
  emitCount            Int     @default(0)
  totalBackpressureMs  Int     @default(0)
}

model LatencySample {
  id             Int      @id @default(autoincrement())
  latencyMs      Int
  sentAt         DateTime @default(now())
  ingestionMs    Int      @default(0)
  queueWaitMs    Int      @default(0)
  processingMs   Int      @default(0)
  emitMs         Int      @default(0)
  backpressureMs Int      @default(0)
  totalMs        Int      @default(0)
}

model BotEvent {
  id        Int      @id @default(autoincrement())
  type      String
  message   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model ClientSession {
  tokenHash     String   @id
  discordUserId String
  displayName   String
  guildId       String
  createdAt     DateTime @default(now())

  @@unique([discordUserId, guildId])
}

model BroadcastLog {
  id          Int      @id @default(autoincrement())
  runId       String
  guildId     String
  channelId   String?
  status      String
  errorCode   String?
  errorReason String?
  createdAt   DateTime @default(now())

  @@index([runId])
  @@index([guildId])
  @@index([status])
}
