generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Queue {
  id String @id @default(uuid())

  type    String
  content String

  author      String?
  authorImage String?

  submissionDate DateTime @default(now())
  executionDate  DateTime @default(now())
  duration       Int
  discordGuildId String

  @@index([type])
}

model Guild {
  id               String    @id
  busyUntil        DateTime?
  defaultMediaTime Int?
  maxMediaTime     Int?
  displayMediaFull Boolean   @default(false)
  channelId        String?
}

model Stats {
  id                String @id @default("singleton")
  totalSent         Int    @default(0)
  imageCount        Int    @default(0)
  videoCount        Int    @default(0)
  audioCount        Int    @default(0)
  linkCount         Int    @default(0)
  textCount         Int    @default(0)
  totalLatencyMs    Int    @default(0)
  latencyCount      Int    @default(0)
  totalPayloadBytes Int    @default(0)
}

model LatencySample {
  id        Int      @id @default(autoincrement())
  latencyMs Int
  sentAt    DateTime @default(now())
}

model BotEvent {
  id        Int      @id @default(autoincrement())
  type      String
  message   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
